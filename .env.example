# Copy to .env and fill in ONE of the two API keys (Anthropic wins if both set).
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
MODEL=claude-haiku-4-5
# :free route runs the whole pipeline at $0 (slower); paid e.g. deepseek/deepseek-v4-flash is ~$0.02/run
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
DATA_DIR=data
OUTPUT_DIR=outputs
# "Today" for the simulation (Day 14). Change to re-run for another day.
RUN_DATE=2025-10-14
